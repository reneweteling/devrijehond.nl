{
  "name": "devrijehond",
  "version": "0.0.0",
  "private": true,
  "description": "De Vrije Hond — community map of dog-friendly spots in the Netherlands. Expo app + Next.js API/website.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run check-types",
    "test": "turbo run test",
    "format": "prettier --write .",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "generate": "turbo run generate",
    "ios:release": "pnpm --filter mobile ios:release",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": "prettier --write"
  }
}
