# Production-facing public config, committed so every release build inlines the
# same values deterministically (the Xcode "Bundle React Native" phase runs
# without NODE_ENV and would otherwise only see .env / .env.local).
#
# These are all EXPO_PUBLIC_* — public by definition, inlined into the JS bundle.
# NO secrets here. Local development overrides this via .env.development.local
# (gitignored), e.g. EXPO_PUBLIC_API_URL=http://localhost:3030, which Expo loads
# at higher precedence when NODE_ENV=development.
EXPO_PUBLIC_API_URL=https://api.devrijehond.nl
EXPO_PUBLIC_AUTH_URL=https://api.devrijehond.nl
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=762592672284-cr47iv5jq6d0p2ghvmrcrf1lar90vpiq.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=762592672284-8atreoupa0ic702gnrg61bds9h88qrmp.apps.googleusercontent.com
# Sentry DSN for the mobile app. Public/publishable — safe to commit.
# Get it from: https://sentry.io -> your project -> Settings -> Client Keys (DSN).
EXPO_PUBLIC_APP_SENTRY_DSN=https://b022b0989e2fafe914a041b0455a78e6@o157871.ingest.us.sentry.io/4511613482500096
