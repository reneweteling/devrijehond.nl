# Local dev env for the De Vrije Hond Expo app.
#
# Copy to `.env.development.local` (NOT `.env.local`).
#
# Why `.env.development.local`: Expo loads `.env.local` regardless of NODE_ENV,
# so a dev override there silently wins over EAS env at `eas update` / `eas
# build` time (those run with NODE_ENV=production). `.env.development.local` is
# only loaded by the Expo dev server (NODE_ENV=development), so it can't leak a
# localhost origin into a shipped bundle.
#
# Every EXPO_PUBLIC_* must be referenced via a LITERAL `process.env.NAME` access
# (see lib/config.ts) so Babel can inline it at bundle time. `lib/config.ts`
# throws at module load if EXPO_PUBLIC_API_URL is empty, so a misconfig surfaces
# at boot, not at the first request.

# REST surface (public /api/v1/* reads + /api/v1/me/* writes), hit via the
# generated @devrijehond/api-client.
EXPO_PUBLIC_API_URL=https://devrijehond.local

# BetterAuth origin (/api/auth/*). Falls back to EXPO_PUBLIC_API_URL when unset
# (single Next server in local dev serves both API and auth).
EXPO_PUBLIC_AUTH_URL=https://devrijehond.local

# Web OAuth client id for native Google Sign-In (Android picker). Public, not a
# secret. When unset the native Google flow is unavailable.
# EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
