# ---- Database (PostGIS via docker-compose) ----
DATABASE_URL="postgresql://devrijehond:devrijehond@localhost:5432/devrijehond?schema=public"

# ---- BetterAuth ----
BETTER_AUTH_SECRET="change-me-32-byte-random"
BETTER_AUTH_BASE_URL="https://app.devrijehond.local"
BETTER_AUTH_TRUSTED_ORIGINS="https://app.devrijehond.local,https://admin.devrijehond.local"

# Native Apple Sign In (App Store guideline 4.8)
APPLE_CLIENT_ID="nl.devrijehond.app"
APPLE_BUNDLE_ID="nl.devrijehond.app"
APPLE_CLIENT_SECRET=""

# Native Google Sign In (Android uses the WEB client id as token audience)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Email (Resend) ----
RESEND_API_KEY=""
EMAIL_FROM="De Vrije Hond <hallo@devrijehond.nl>"

# ---- S3 (avatars, dog + spot photos) ----
S3_BUCKET=""
S3_REGION="eu-west-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ---- Mobile (EXPO_PUBLIC_*) ----
EXPO_PUBLIC_API_URL="https://app.devrijehond.local"
