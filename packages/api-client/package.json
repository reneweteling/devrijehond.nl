{
  "name": "@devrijehond/api-client",
  "version": "0.0.0",
  "private": true,
  "description": "Orval-generated TypeScript client + TanStack Query hooks for the De Vrije Hond API. Consumed by apps/mobile. Regenerated from the OpenAPI document compiled by @devrijehond/types.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "generate": "orval --config orval.config.ts",
    "snapshot": "curl -sSf https://devrijehond.local/api/v1/openapi.json > ./openapi.snapshot.json && pnpm generate",
    "check-types": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "orval": "^7.9.0",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.81.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  }
}
