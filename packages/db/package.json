{
  "name": "@devrijehond/db",
  "version": "0.0.0",
  "private": true,
  "description": "ZenStack v3 schema, access policies, generated client, Zod factory and seed for De Vrije Hond.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schema": {
      "types": "./schema.ts",
      "default": "./schema.ts"
    },
    "./models": {
      "types": "./models.ts",
      "default": "./models.ts"
    },
    "./zod": {
      "types": "./src/zod.ts",
      "default": "./src/zod.ts"
    }
  },
  "scripts": {
    "db:generate": "zen generate",
    "db:push": "zen db push",
    "db:migrate": "zen migrate dev",
    "db:migrate:deploy": "zen migrate deploy",
    "db:deploy": "node ensure-postgis.mjs && zen migrate deploy",
    "db:seed": "tsx --env-file-if-exists=../../.env.local seed.ts",
    "db:release": "node ensure-postgis.mjs && zen migrate deploy && tsx --env-file-if-exists=../../.env.local seed.ts",
    "build": "zen generate",
    "check-types": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@devrijehond/s3": "workspace:*",
    "@zenstackhq/better-auth": "^3.0.0",
    "@zenstackhq/orm": "^3.0.0",
    "@zenstackhq/plugin-policy": "^3.0.0",
    "@zenstackhq/schema": "^3.0.0",
    "@zenstackhq/zod": "^3.0.0",
    "pg": "^8.13.1",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.2.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/sharp": "^0.32.0",
    "@zenstackhq/cli": "^3.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "zenstack": {
    "schema": "schema.zmodel"
  }
}
